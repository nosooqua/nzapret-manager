#!/usr/bin/env bash
# nzapret-manager — Ubuntu DPI bypass manager (zapret wrapper)
#
# Usage:
#   nzapret-manager                    open the TUI
#   nzapret-manager install            install bol-van/zapret + systemd unit
#   nzapret-manager update             update zapret to latest origin/HEAD
#   nzapret-manager uninstall          remove zapret entirely
#   nzapret-manager apply <id>         apply strategy by id (v1..v9, Yv01.., Dv1..Dv17)
#   nzapret-manager list [scope]       list strategies (builtin|youtube|discord|all)
#   nzapret-manager preview <id>       print the body of a strategy
#   nzapret-manager current            show currently applied strategy
#   nzapret-manager test [scope]       parallel-curl auto-test (general|youtube|discord|all)
#   nzapret-manager fetch-youtube      (re)fetch the YouTube strategy catalog
#   nzapret-manager hosts <enable|disable|list> [name]
#   nzapret-manager service <start|stop|restart|enable|disable|status>
#   nzapret-manager backup <create|list|restore <file>|prune [N]>
#   nzapret-manager version

set -uo pipefail

NZAPRET_MANAGER_HOME=$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
LIB="${NZAPRET_MANAGER_HOME}/lib"
NZAPRET_MANAGER_DIR="$NZAPRET_MANAGER_HOME"

# shellcheck source=/dev/null
. "${LIB}/common.sh"
# shellcheck source=/dev/null
. "${LIB}/deps.sh"
# shellcheck source=/dev/null
. "${LIB}/service.sh"
# shellcheck source=/dev/null
. "${LIB}/zapret.sh"
# shellcheck source=/dev/null
. "${LIB}/strategies.sh"
# shellcheck source=/dev/null
. "${LIB}/strategy_test.sh"
# shellcheck source=/dev/null
. "${LIB}/hosts.sh"
# shellcheck source=/dev/null
. "${LIB}/backup.sh"
# shellcheck source=/dev/null
. "${LIB}/menu.sh"

require_ubuntu

cmd="${1:-}"
shift || true

case "$cmd" in
    ''|menu)         require_root; ensure_dirs; menu_main ;;
    install)         require_root; zapret_install ;;
    update)          require_root; zapret_update ;;
    uninstall|remove) require_root; zapret_remove ;;
    apply)
        [[ -n ${1:-} ]] || die "Usage: nzapret-manager apply <id>"
        strategies_apply "$1"
        ;;
    list)
        case "${1:-all}" in
            builtin) strategies_list_builtin | column -t -s $'\t' ;;
            youtube) strategies_ensure_youtube; strategies_list_youtube | column -t -s $'\t' ;;
            discord) strategies_list_discord | column -t -s $'\t' ;;
            all)     strategies_list_all     | column -t -s $'\t' ;;
            *)       die "Unknown scope: ${1}" ;;
        esac
        ;;
    preview)
        [[ -n ${1:-} ]] || die "Usage: nzapret-manager preview <id>"
        strategies_preview "$1"
        ;;
    current)         strategies_show_current ;;
    test)            strategy_test_run "${1:-all}" ;;
    fetch-youtube)   strategies_fetch_youtube ;;
    hosts)
        sub="${1:-list}"; shift || true
        case "$sub" in
            list)
                for b in $(hosts_blocks_available); do
                    local_mark="-"; hosts_block_enabled "$b" && local_mark="+"
                    printf '%s %-18s %s\n' "$local_mark" "$b" "$(hosts_label_for "$b" || true)"
                done
                ;;
            enable)  [[ -n ${1:-} ]] || die "Usage: nzapret-manager hosts enable <name>";  hosts_enable "$1" ;;
            disable) [[ -n ${1:-} ]] || die "Usage: nzapret-manager hosts disable <name>"; hosts_disable "$1" ;;
            disable-all) hosts_disable_all ;;
            *) die "Unknown hosts subcommand: $sub" ;;
        esac
        ;;
    service)
        sub="${1:-status}"; shift || true
        case "$sub" in
            start)   service_start ;;
            stop)    service_stop ;;
            restart) service_restart ;;
            enable)  service_enable ;;
            disable) service_disable ;;
            status)  service_show_status ;;
            log)     service_tail_log "${1:-100}" ;;
            *) die "Unknown service subcommand: $sub" ;;
        esac
        ;;
    backup)
        sub="${1:-list}"; shift || true
        case "$sub" in
            create)  backup_create ;;
            list)    backup_list ;;
            restore) [[ -n ${1:-} ]] || die "Usage: nzapret-manager backup restore <file>"; backup_restore "$1" ;;
            prune)   backup_prune "${1:-5}" ;;
            *) die "Unknown backup subcommand: $sub" ;;
        esac
        ;;
    version|-v|--version)
        printf 'nzapret-manager %s\n' "$(git -C "$NZAPRET_MANAGER_HOME" rev-parse --short HEAD 2>/dev/null || echo unknown)"
        zapret_print_versions
        ;;
    help|-h|--help)
        sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
        ;;
    *) die "Unknown command: $cmd. Try: nzapret-manager help" ;;
esac
